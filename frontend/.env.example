# Backend API URL
# In dev: leave empty (Vite proxy handles /api → localhost:8000)
# In prod: set to your Render backend URL
VITE_API_URL=https://your-backend.onrender.com/api

# Rulebook / Settings shared password
VITE_RULEBOOK_PASSWORD=your-settings-password

# Authorised rulebook managers (email + password per user)
VITE_USER1_NAME=Full Name One
VITE_USER1_EMAIL=user1@company.com
VITE_USER1_PASSWORD=password1

VITE_USER2_NAME=Full Name Two
VITE_USER2_EMAIL=user2@company.com
VITE_USER2_PASSWORD=password2

VITE_USER3_NAME=Full Name Three
VITE_USER3_EMAIL=user3@company.com
VITE_USER3_PASSWORD=password3
